# ========== 腾讯云 SOE 口语评测凭证（必填） ==========
# 访问 https://console.cloud.tencent.com/cam/capi 获取
TC_SECRET_ID=your_secret_id_here
TC_SECRET_KEY=your_secret_key_here

# ========== 应用配置（可选） ==========
TC_APP_ID=1410036406

# 服务器端口（默认 8126）
SOE_PORT=8126

# CORS 白名单（生产环境建议锁定为 GitHub Pages 域名）
# 多个用逗号分隔，不设则允许所有来源
# CORS_ORIGINS=https://dl2012777.github.io

# ffmpeg 路径（留空自动检测）
# FFMPEG_PATH=/usr/bin/ffmpeg
